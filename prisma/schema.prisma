generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model User {
  id        Int        @id @default(autoincrement())
  username  String
  email     String     @unique
  password  String

  favorites Favorite[]
}

model Announcement {
  id          Int        @id @default(autoincrement())
  title       String
  description String
  type        String
  platform    String
  price       Float

  favorites   Favorite[]
}

model Favorite {
  id             Int @id @default(autoincrement())

  userId         Int
  announcementId Int

  user           User @relation(fields: [userId], references: [id])
  announcement   Announcement @relation(fields: [announcementId], references: [id])
}