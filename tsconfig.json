{
  "compilerOptions": {
    "target": "ES2020",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",

    "rootDir": "./backend/src",
    "outDir": "./backend/dist",

    "strict": true,
    "esModuleInterop": true,

    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,

    "sourceMap": true
  },

  "include": ["backend/src/**/*"],
  "exclude": ["node_modules", "backend/dist"]
}